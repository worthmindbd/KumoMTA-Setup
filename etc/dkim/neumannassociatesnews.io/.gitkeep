# Place the DKIM private key here as: pmta.key
#
# This is the SAME key PowerMTA used (selector "pmta"). Do NOT regenerate it,
# or DKIM will fail until DNS propagates. Copy your backed-up key:
#
#   cp /your/backup/etc/pmta/pmta.pem \
#      /opt/kumomta/etc/dkim/neumannassociatesnews.io/pmta.key
#   chown kumod:kumod /opt/kumomta/etc/dkim/neumannassociatesnews.io/pmta.key
#   chmod 600        /opt/kumomta/etc/dkim/neumannassociatesnews.io/pmta.key
#
# The .key / .pem files are git-ignored on purpose -- never commit private keys.
